# Copy this file to .env and fill in your key.
#   cp .env.example .env

# Required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Defaults shown.
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=none

# Uncomment to print AI debug output to the terminal.
# CABIN_DEBUG=1
